# ============================================================================
#  ScribIA v2 — Configuration environnement (GPU externe via RAG)
# ============================================================================

# ── Database (MSSQL) ─────────────────────────────────────────────────────────
DB_PASSWORD=CHANGEZ_MOI_EN_PRODUCTION!
SCRIBIA_DB_HOST=db
SCRIBIA_DB_PORT=1433
SCRIBIA_DB_NAME=scribia
SCRIBIA_DB_USER=sa
SCRIBIA_DB_PASSWORD=CHANGEZ_MOI_EN_PRODUCTION!

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generez une cle securisee : python -c "import secrets; print(secrets.token_urlsafe(64))"
SCRIBIA_JWT_SECRET=CHANGEZ_MOI_EN_PRODUCTION
SCRIBIA_JWT_EXPIRE_MINUTES=1440

# ── CORS ─────────────────────────────────────────────────────────────────────
SCRIBIA_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── RAG externe ──────────────────────────────────────────────────────────────
# URL du rag-api (port par defaut: 8000, cf RAG_API_PORT dans le .env du RAG)
# Cette URL unique sert pour tout : /v1/chat, /v1/ingest ET /v1/transcribe
SCRIBIA_RAG_API_URL=http://192.168.9.16:8000
SCRIBIA_RAG_API_KEY=rak_CHANGEZ_MOI
# SCRIBIA_RAG_PROJECT_ID=default

# Transcription + diarisation deleguees au RAG (whisper + pyannote sur GPU distant)
# Necessite cote RAG : WHISPER_ENABLED=true et PYANNOTE_ENABLED=true
SCRIBIA_USE_EXTERNAL_TRANSCRIPTION=true

# ── Debug ────────────────────────────────────────────────────────────────────
# SCRIBIA_DEBUG=true
