# ============================================================================
#  ScribIA v2 — Configuration environnement
#
#  Choisissez votre architecture et copiez le fichier correspondant en .env :
#
#  .env.archi-1-tout-en-un     → Front + Back + MSSQL Docker sur 1 machine
#  .env.archi-2-mssql-local    → Front séparé, Back + MSSQL Docker sur même machine
#  .env.archi-3-mssql-distant  → Front (A) + Back (B) + MSSQL natif Windows (C) sur 3 machines
# ============================================================================


# ── Database (MSSQL) ─────────────────────────────────────────────────────────
DB_PASSWORD=CHANGEZ_MOI_EN_PRODUCTION!

SCRIBIA_DB_HOST=db
SCRIBIA_DB_PORT=1433
SCRIBIA_DB_NAME=scribia
SCRIBIA_DB_USER=sa
SCRIBIA_DB_PASSWORD=CHANGEZ_MOI_EN_PRODUCTION!


# ── JWT ──────────────────────────────────────────────────────────────────────
# Générez une clé sécurisée : python -c "import secrets; print(secrets.token_urlsafe(64))"
SCRIBIA_JWT_SECRET=CHANGEZ_MOI_EN_PRODUCTION
SCRIBIA_JWT_EXPIRE_MINUTES=1440


# ── CORS ─────────────────────────────────────────────────────────────────────
SCRIBIA_CORS_ORIGINS=http://localhost:3000,http://localhost:5173


# ── Diarisation (pyannote.audio) ──────────────────────────────────────────────
# Token HuggingFace pour pyannote. Créez-le sur https://huggingface.co/settings/tokens
# Vous devez aussi accepter les conditions sur :
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
SCRIBIA_HF_TOKEN=


# ── RAG externe ──────────────────────────────────────────────────────────────
# URL du rag-api et API key (format rak_...)
SCRIBIA_RAG_API_URL=http://192.168.9.16:8000
SCRIBIA_RAG_API_KEY=rak_CHANGEZ_MOI
# Project ID fixe pour tous les tenants (Option A : 1 projet RAG par tenant)
# SCRIBIA_RAG_PROJECT_ID=default
# Déléguer Whisper+pyannote au rag-api (true = transcription distante, false = locale GPU)
# SCRIBIA_USE_EXTERNAL_TRANSCRIPTION=false

# ── Services RAG (profil rag) ───────────────────────────────────────────────
# Redis (cache + queues pour le rag-api)
# REDIS_PORT=6379
# Qdrant (base vectorielle)
# QDRANT_PORT=6333
# QDRANT_GRPC_PORT=6334
# MinIO (stockage objets)
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGEZ_MOI_EN_PRODUCTION

# ── Debug ────────────────────────────────────────────────────────────────────
# SCRIBIA_DEBUG=true
