# ============================================================================
#  ARCHITECTURE 3 : Front, Back et MSSQL sur 3 machines séparées
#  ┌──────────────┐     ┌──────────────┐     ┌──────────────────────┐
#  │  Machine A   │     │  Machine B   │     │  Machine C (Windows) │
#  │  ┌─────────┐ │     │  ┌─────────┐ │     │ ┌──────────────────┐ │
#  │  │Frontend │── TCP ──→│ Backend │── TCP ──→│ MSSQL (natif)    │ │
#  │  │ :3001   │ │     │  │  :8001  │ │     │ │     :1433        │ │
#  │  │ Docker  │ │     │  │ Docker  │ │     │ │ Windows Server   │ │
#  │  └─────────┘ │     │  └─────────┘ │     │ └──────────────────┘ │
#  └──────────────┘     └──────────────┘     └──────────────────────┘
#
#  Machine A : docker-compose up frontend
#  Machine B : docker-compose up backend
#  Machine C : MSSQL installé nativement sur Windows
# ============================================================================


# ── Database (MSSQL natif sur serveur Windows — Machine C) ───────────────────
# Remplacer par l'IP ou le hostname du serveur Windows
SCRIBIA_DB_HOST=192.168.1.100
SCRIBIA_DB_PORT=1433
SCRIBIA_DB_NAME=scribia
SCRIBIA_DB_USER=scribia_app
SCRIBIA_DB_PASSWORD=MotDePasse_Securise!


# ── JWT ──────────────────────────────────────────────────────────────────────
SCRIBIA_JWT_SECRET=REMPLACEZ_PAR_UNE_CLE_SECURISEE
SCRIBIA_JWT_EXPIRE_MINUTES=1440


# ── CORS (autoriser le domaine du frontend sur Machine A) ────────────────────
SCRIBIA_CORS_ORIGINS=https://scribia.votre-domaine.fr


# ── Diarisation (pyannote.audio) ──────────────────────────────────────────────
SCRIBIA_HF_TOKEN=


# ── Debug ────────────────────────────────────────────────────────────────────
SCRIBIA_DEBUG=false


# ============================================================================
#  INSTRUCTIONS — Machine C (serveur Windows — MSSQL)
# ============================================================================
#
#  1. Installer SQL Server (Standard, Developer ou Express)
#
#  2. Ouvrir SSMS et exécuter :
#
#     CREATE DATABASE scribia;
#     GO
#     CREATE LOGIN scribia_app WITH PASSWORD = 'MotDePasse_Securise!';
#     GO
#     USE scribia;
#     CREATE USER scribia_app FOR LOGIN scribia_app;
#     ALTER ROLE db_owner ADD MEMBER scribia_app;
#     GO
#
#  3. Activer TCP/IP dans SQL Server Configuration Manager :
#     - Protocoles pour MSSQLSERVER → TCP/IP → Activé
#     - Propriétés TCP/IP → IPAll → Port TCP = 1433
#     - Redémarrer le service SQL Server
#
#  4. Pare-feu Windows :
#     - Autoriser le port 1433 en entrée (TCP)
#     - Tester depuis Machine B : telnet 192.168.1.100 1433
#
# ============================================================================
#  INSTRUCTIONS — Machine B (Backend)
# ============================================================================
#
#  1. Copier ce fichier en .env, adapter SCRIBIA_DB_HOST vers Machine C
#
#  2. Supprimer ou renommer docker-compose.override.yml
#
#  3. Lancer :
#     docker-compose up backend
#
# ============================================================================
#  INSTRUCTIONS — Machine A (Frontend)
# ============================================================================
#
#  1. Modifier nginx.conf pour pointer vers Machine B :
#
#     location /api/ {
#         proxy_pass http://IP_MACHINE_B:8001/;
#         proxy_set_header Host $host;
#         proxy_set_header X-Real-IP $remote_addr;
#         proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#         proxy_set_header X-Forwarded-Proto $scheme;
#     }
#
#  2. docker-compose up frontend
#
# ============================================================================
